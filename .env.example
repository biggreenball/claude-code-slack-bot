# Slack App Configuration
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_SIGNING_SECRET=your-signing-secret

# Access control — comma-separated Slack user IDs allowed to use the bot.
# REQUIRED. Bot refuses to start if empty. Look up your user ID via Slack
# profile "More" menu → "Copy member ID" (format: U01ABCD2345).
ALLOWED_SLACK_USER_IDS=U01ABCD2345

# HMAC secret for signing approve/deny decision files written by the bot
# and verified by the permission-prompt MCP subprocess. REQUIRED, >=32 chars.
# Generate once with: openssl rand -hex 32
# Defense-in-depth against forged decision files (stale replays, accidental
# writes); NOT a hard boundary against an in-process root attacker — see
# PUNCHLIST for the out-of-band-confirmation follow-up.
APPROVAL_HMAC_SECRET=replace-with-openssl-rand-hex-32

# Claude Code Configuration — optional on TRC1. When run as root the bot
# inherits subscription auth from /root/.claude/.credentials.json. Only set
# ANTHROPIC_API_KEY if you want pay-per-token API access instead.
# ANTHROPIC_API_KEY=your-anthropic-api-key

# Working Directory Configuration
# Base directory for relative paths. If set, you can use "cwd project-name"
# instead of full paths. Default on TRC1: /opt/
BASE_DIRECTORY=/opt/

# Optional: Use third-party providers
# CLAUDE_CODE_USE_BEDROCK=1
# CLAUDE_CODE_USE_VERTEX=1

# Development
# DEBUG=true