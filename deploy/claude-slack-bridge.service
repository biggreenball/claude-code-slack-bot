[Unit]
Description=Claude Slack Bridge — personal Slack → Claude Code CLI transport
After=network-online.target
Wants=network-online.target
# Restart unbounded normally, but cap restart-loop frequency below to avoid
# burning CPU if the bot crashes immediately on startup.
StartLimitBurst=5
StartLimitIntervalSec=60

[Service]
Type=simple
User=root
Group=root
WorkingDirectory=/opt/claude-slack-bridge
EnvironmentFile=/opt/claude-slack-bridge/.env
Environment=NODE_ENV=production
Environment=HOME=/root
ExecStart=/opt/claude-slack-bridge/node_modules/.bin/tsx src/index.ts
Restart=always
RestartSec=5s
StandardOutput=journal
StandardError=journal
SyslogIdentifier=claude-slack-bridge

# Persistent state directory for in-flight approval IPC files.
# systemd creates /var/lib/claude-slack-bridge with mode 0700 owned by the
# service user, so files survive reboot but other users can't read them.
StateDirectory=claude-slack-bridge
StateDirectoryMode=0700

# Resource caps — generous but prevent runaways from wedging TRC1.
MemoryMax=2G
LimitNOFILE=8192
TasksMax=512

# Keep the OOM killer away — this bot is more important than transient memory
# pressure recovery; if the bot OOMs we want to know via crash, not silent
# eviction.
OOMScoreAdjust=-1000

# No filesystem sandboxing (PrivateTmp/ProtectSystem/etc.) — Claude Code needs
# unrestricted root filesystem access, that's the whole point of this bot.
# CapabilityBoundingSet is similarly left wide because we run as root and
# Claude tools need full capability set.

[Install]
WantedBy=multi-user.target
